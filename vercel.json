{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/(assets|public|src)/(.*)",
            "dest": "frontend/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "frontend/favicon.ico"
        },
        {
            "src": "/vite.svg",
            "dest": "frontend/vite.svg"
        },
        {
            "src": "/((?!api/).*)",
            "dest": "frontend/index.html"
        }
    ]
}